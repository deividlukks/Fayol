{
  "name": "telegram-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "lint": "eslint . --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "telegraf": "^4.15.3",
    "telegraf-session-local": "^2.1.1",
    "@fayol/ai-services": "workspace:*",
    "@fayol/api-client": "workspace:*",
    "@fayol/integrations": "workspace:*",
    "@fayol/shared-constants": "workspace:*",
    "@fayol/shared-types": "workspace:*",
    "@fayol/shared-utils": "workspace:*",
    "@fayol/validation-schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "eslint": "^9.39.1",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "axios-mock-adapter": "^1.22.0"
  }
}
