    "react-native-screens": "^4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "typescript": "~5.9.2"
