{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@fayol/shared-types": ["packages/shared-types/src"],
      "@fayol/shared-types/*": ["packages/shared-types/src/*"],
      "@fayol/shared-utils": ["packages/shared-utils/src"],
      "@fayol/shared-utils/*": ["packages/shared-utils/src/*"],
      "@fayol/shared-constants": ["packages/shared-constants/src"],
      "@fayol/shared-constants/*": ["packages/shared-constants/src/*"],
      "@fayol/validation-schemas": ["packages/validation-schemas/src"],
      "@fayol/validation-schemas/*": ["packages/validation-schemas/src/*"],
      "@fayol/database-models": ["packages/database-models/src"],
      "@fayol/database-models/*": ["packages/database-models/src/*"],
      "@fayol/api-client": ["packages/api-client/src"],
      "@fayol/api-client/*": ["packages/api-client/src/*"],
      "@fayol/ui-components": ["packages/ui-components/src"],
      "@fayol/ui-components/*": ["packages/ui-components/src/*"],
      "@fayol/ai-services": ["packages/ai-services/src"],
      "@fayol/ai-services/*": ["packages/ai-services/src/*"],
      "@fayol/integrations": ["packages/integrations/src"],
      "@fayol/integrations/*": ["packages/integrations/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "build", ".next"]
}