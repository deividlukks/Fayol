# ==============================================
# 🌍 FAYOL - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# ==============================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env
# ==============================================

NODE_ENV=development

# --- BANCO DE DADOS (POSTGRES) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fayol_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL usada pelo Prisma dentro do Container Backend
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- REDIS (CACHE & QUEUE) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MONGODB (LOGS) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_DB=fayol_logs
MONGO_PORT=27017

# --- SEGURANÇA (JWT) ---
# IMPORTANTE: Gere um secret forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_here_change_me"
JWT_EXPIRATION=1d

# --- APLICAÇÕES ---
# Portas expostas para o Host (Sua máquina)
PORT_BACKEND=3333
PORT_WEB=3000
PORT_AI=8000

# --- INTEGRAÇÕES EXTERNAS ---
# Token do Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# URLs Internas (Comunicação Docker <-> Docker)
API_BASE_URL="http://backend:3333/api"

# Para desenvolvimento local (Backend no terminal -> IA no Docker), use localhost

# ============================================================================
# FASE 8 - DevOps & CI/CD Configuration
# ============================================================================

# Database Configuration (Docker)
DB_USER=fayol
DB_PASSWORD=fayol_dev_pass
DB_NAME=fayol_dev

# Redis Configuration
REDIS_PASSWORD=redis_dev_pass

# JWT Configuration
JWT_EXPIRATION=24h

# AWS Configuration (para CI/CD)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_ECR_REGISTRY=your_account_id.dkr.ecr.us-east-1.amazonaws.com

# GitHub Container Registry
GHCR_REGISTRY=ghcr.io/your-org
GHCR_USERNAME=your_github_username
GHCR_TOKEN=your_github_token

# Slack Webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Monitoring (Fase 9)
SENTRY_DSN=https://your_sentry_dsn
PROMETHEUS_PUSHGATEWAY=http://prometheus-pushgateway:9091

# Third-party Services
SNYK_TOKEN=your_snyk_token
SONAR_TOKEN=your_sonar_token
LHCI_GITHUB_APP_TOKEN=your_lhci_token
AI_SERVICE_URL="http://localhost:8000"

# URL Pública (Para o Frontend acessar a API do navegador)
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
