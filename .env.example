# ==============================================
# 🌍 FAYOL - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# ==============================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env
# ==============================================

NODE_ENV=development

# --- BANCO DE DADOS (POSTGRES) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fayol_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL usada pelo Prisma dentro do Container Backend
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- REDIS (CACHE & QUEUE) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MONGODB (LOGS) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_DB=fayol_logs
MONGO_PORT=27017

# --- SEGURANÇA (JWT) ---
# IMPORTANTE: Gere um secret forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_here_change_me"
JWT_EXPIRATION=1d

# --- APLICAÇÕES ---
# Portas expostas para o Host (Sua máquina)
PORT_BACKEND=3333
PORT_WEB=3000
PORT_AI=8000

# --- INTEGRAÇÕES EXTERNAS ---
# Token do Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# URLs Internas (Comunicação Docker <-> Docker)
API_BASE_URL="http://backend:3333/api"

# Para desenvolvimento local (Backend no terminal -> IA no Docker), use localhost
AI_SERVICE_URL="http://localhost:8000"

# URL Pública (Para o Frontend acessar a API do navegador)
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
