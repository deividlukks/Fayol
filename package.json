{
  "name": "fayol",
  "version": "0.1.0",
  "description": "Sistema Multiplataforma de Gestão Financeira Pessoal com IA",
  "private": true,
  "author": "Deivid Lucas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deividlukks/fayol.git"
  },
  "scripts": {
    "dev": "pnpm run validate-env && turbo run dev --parallel",
    "build": "turbo run build",
    "//postinstall": "pnpm --filter @fayol/database-models run generate",
    "generate": "turbo run generate",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:integration": "turbo run test:e2e",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "turbo run test:e2e",
    "test:all": "pnpm run test:unit && pnpm run test:integration",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "type-check": "turbo run type-check",
    "start": "pnpm run validate-env && turbo run start",
    "clean": "turbo run clean && rimraf node_modules",
    "clean:workspaces": "turbo run clean",
    "setup": "pnpm install && pnpm run prepare",
    "prepare": "husky",
    "validate-env": "node scripts/validate-env.js",
    "validate-env:test": "NODE_ENV=test node scripts/validate-env.js",
    "validate-env:prod": "NODE_ENV=production node scripts/validate-env.js",
    "docker:manager": "bash scripts/docker-compose-manager.sh || cmd.exe /c scripts\\docker-compose-manager.bat",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:status": "docker-compose ps",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "docker:validate": "bash scripts/docker-compose-manager.sh validate || cmd.exe /c scripts\\docker-compose-manager.bat validate"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.1.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.1.0",
    "turbo": "^2.6.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@opentelemetry/instrumentation": "^0.54.2",
    "@opentelemetry/instrumentation-express": "^0.44.0",
    "@opentelemetry/instrumentation-http": "^0.54.2",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@sentry/node": "^10.29.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/sdk-trace-base": "^1.28.0"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
