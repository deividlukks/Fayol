# ==============================================
# 🌍 FAYOL - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# ==============================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env
# ==============================================

NODE_ENV=development

# --- BANCO DE DADOS (POSTGRES) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fayol_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL para desenvolvimento local (fora do Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fayol_dev?schema=public"
# URL para uso dentro do Docker (não usar em dev local)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/fayol_dev?schema=public"

# --- REDIS (CACHE & QUEUE) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MONGODB (LOGS) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_DB=fayol_logs
MONGO_PORT=27017

# --- SEGURANÇA (JWT) ---
# IMPORTANTE: Gere um secret forte com: node -e "console.log(require('crypto').randomBytes(256).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRATION=1d

# --- APLICAÇÕES ---
# Portas expostas para o Host (Sua máquina)
PORT_BACKEND=3333
PORT_WEB=3000
PORT_AI=8000

# --- INTEGRAÇÕES EXTERNAS ---
# Token do Telegram
TELEGRAM_BOT_TOKEN="8498223393:AAFv171_5-oNMiheKojVAhjWMC-8Z2s1gvA"

# URLs Internas (Comunicação Docker <-> Docker)
API_BASE_URL="http://backend:3333/api"

# Para desenvolvimento local (Backend no terminal -> IA no Docker), use localhost
AI_SERVICE_URL="http://localhost:8000"

# URL Pública (Para o Frontend acessar a API do navegador)
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
