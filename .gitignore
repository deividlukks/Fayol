# ============================================================================
# FAYOL PROJECT - .gitignore
# ============================================================================

# ============================================================================
# Dependencies & Package Management
# ============================================================================
node_modules/
*.pnp
.pnp.js
.pnp.cjs

# Dependency locks (use pnpm-lock.yaml only for this monorepo)
package-lock.json
yarn.lock
npm-shrinkwrap.json

# ============================================================================
# Build & Distribution
# ============================================================================
dist/
build/
.next/
out/
.turbo/
turbo.log

# Build outputs by app
apps/backend/dist/
apps/web-app/.next/
apps/web-app/out/

# ============================================================================
# Environment Variables & Secrets
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.awcache/
.eslintcache

# ============================================================================
# Operating System
# ============================================================================
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Thumbs.db
.vscode-settings/

# ============================================================================
# Logging
# ============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log.*

# ============================================================================
# Testing & Coverage
# ============================================================================
coverage/
.nyc_output/
*.lcov
.jest_cache/
.jest/

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
tmp/
temp/
.cache
.tmp/

# ============================================================================
# Database
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
database.sqlite

# Prisma
.prisma/

# ============================================================================
# Python & AI Services
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/

# ============================================================================
# Mobile Apps
# ============================================================================
# Android
apps/mobile-android/.gradle/
apps/mobile-android/.android/
apps/mobile-android/build/
apps/mobile-android/app/debug/
apps/mobile-android/app/release/
apps/mobile-android/local.properties

# iOS
apps/mobile-ios/Pods/
apps/mobile-ios/Podfile.lock
apps/mobile-ios/build/
apps/mobile-ios/.xcode.env.local

# ============================================================================
# Docker
# ============================================================================
.docker/
docker-compose.override.yml

# ============================================================================
# Uploads & Media
# ============================================================================
uploads/
uploads/documents/**/*.pdf
uploads/images/**/*.jpg
uploads/images/**/*.png
!uploads/.gitkeep

# ============================================================================
# Processing & Temp Files
# ============================================================================
temp/processing/
temp/cache/
temp/exports/
!temp/.gitkeep

# ============================================================================
# VS Code Workspace Settings
# ============================================================================
.vscode/*.json
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/launch.json.example

# ============================================================================
# GitHub & Git
# ============================================================================
.git/
.gitconfig

# ============================================================================
# Backup & Archive Files
# ============================================================================
*.bak
*.backup
*.swp
*.swo
*~
*.bkp
*.orig